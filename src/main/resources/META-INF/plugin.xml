<idea-plugin>
    <id>se.tcmt.aurora</id>
    <name>Aurora AI Assistant</name>
    <vendor email="tyson@tcmt.se" url="https://github.com/raynizm">Tyson La</vendor>

    <description><![CDATA[
        <h3>Aurora - Your AI-Powered Coding Assistant for IntelliJ IDEA</h3>
        <p>Aurora brings the power of AI-assisted coding to IntelliJ IDEA. Chat with your AI assistant, get code suggestions, ask questions about your codebase, and more — all from a sleek tool window.</p>

        <h4>Features:</h4>
        <ul>
            <li><b>Chat Interface</b> — Natural language conversations with AI coding assistance</li>
            <li><b>Multi-Provider Support</b> — OpenAI, Anthropic, and any OpenAI-compatible API</li>
            <li><b>Configurable Models</b> — Choose your model, adjust temperature and token limits</li>
            <li><b>Clean UI</b> — Dark-themed chat panel with message history</li>
        </ul>

        <p><i>Built as an IntelliJ IDEA plugin inspired by Roo Code / Zoo Code for VS Code.</i></p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!-- Extensions -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window -->
        <toolWindow factoryClass="se.tcmt.aurora.toolwindow.AuroraToolWindowFactory"
                    id="Aurora"
                    anchor="right"
                    icon="/icons/aurora.svg"/>

        <!-- Settings -->
        <applicationConfigurable parentId="tools"
                                 instance="se.tcmt.aurora.settings.AuroraSettingsConfigurable"/>

        <!-- Persistent settings state -->
        <applicationService serviceImplementation="se.tcmt.aurora.settings.AuroraSettingsState"/>
    </extensions>

    <!-- Actions -->
    <actions>
        <action id="Aurora.ShowAurora"
                class="se.tcmt.aurora.actions.ShowAuroraAction"
                text="Show Aurora"
                description="Open the Aurora AI Assistant tool window">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- Right-click code actions -->
        <group id="Aurora.CodeActions" text="Aurora" popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="before" relative-to-action="Copy"/>
            
            <action id="Aurora.ExplainCode"
                    class="se.tcmt.aurora.actions.ExplainCodeAction"
                    text="Explain Code"
                    description="Explain the selected code using Aurora AI">
                <add-to-group group-id="Aurora.CodeActions" anchor="first"/>
            </action>
            
            <action id="Aurora.FixCode"
                    class="se.tcmt.aurora.actions.FixCodeAction"
                    text="Fix Issues"
                    description="Fix issues in the selected code using Aurora AI">
                <add-to-group group-id="Aurora.CodeActions"/>
            </action>
            
            <action id="Aurora.ImproveCode"
                    class="se.tcmt.aurora.actions.ImproveCodeAction"
                    text="Improve Code"
                    description="Improve the selected code using Aurora AI">
                <add-to-group group-id="Aurora.CodeActions"/>
            </action>
        </group>
    </actions>
</idea-plugin>
